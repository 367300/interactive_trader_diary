# Django настройки
DJANGO_SECRET_KEY=your_super_secret_key_here_change_me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_LANGUAGE_CODE=ru-RU
DJANGO_TIME_ZONE=Europe/Moscow

# CORS: разрешённые источники для DRF API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (Vite) — базовый URL API.
# По умолчанию — относительный путь `/api`: в dev обслуживается Vite-прокси, в prod — nginx.
# Перекрыть на абсолютный URL имеет смысл только для кросс-хост сценариев.
VITE_API_BASE_URL=/api

# URL React-фронтенда — используется в публичных Django-шаблонах для ссылок на SPA.
# В prod через nginx обычно пусто (ссылки относительные). В dev — http://localhost:3000.
FRONTEND_URL=http://localhost:3000

# PostgreSQL настройки
POSTGRES_DB=trader_diary_db
POSTGRES_USER=trader_user
POSTGRES_PASSWORD=secure_password_123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# RabbitMQ настройки
RABBITMQ_DEFAULT_USER=trader_guest
RABBITMQ_DEFAULT_PASS=trader_password_456

# Celery настройки
CELERY_BROKER_URL=amqp://trader_guest:trader_password_456@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://

# PgAdmin настройки (для разработки)
PGADMIN_DEFAULT_EMAIL=admin@trader-diary.local
PGADMIN_DEFAULT_PASSWORD=admin_password_789

# Flower настройки (мониторинг Celery)
FLOWER_BASIC_AUTH=admin:flower_password_101

# Certbot (только для production, одноразовый запуск)
CERTBOT_EMAIL=admin@example.com
CERTBOT_DOMAIN=example.com

# Системные настройки для Docker
UID=1000
GID=1000
